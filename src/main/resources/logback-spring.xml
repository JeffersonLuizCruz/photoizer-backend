<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="applicationName" source="spring.application.name" defaultValue="crm"/>

    <property name="CONSOLE_TEXT_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %highlight(%-5level) %logger{36} [%X{traceId}] - %msg%n"/>

    <!-- Perfil de Usuário (default) + Desenvolvimento: console texto, DEBUG -->
    <!-- Ativo quando NENHUM dos perfis homolog/prod estiver ativo -->
    <springProfile name="!homolog, !prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${CONSOLE_TEXT_PATTERN}</pattern>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.photoizer.crm" level="DEBUG"/>
        <logger name="com.photoizer.crm.shared.logging" level="WARN"/>
    </springProfile>

    <!-- Perfil de Homologação: JSON console, INFO -->
    <springProfile name="homolog">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdc>true</includeMdc>
                <fieldNames>
                    <timestamp>@timestamp</timestamp>
                    <version>[ignore]</version>
                    <levelValue>[ignore]</levelValue>
                    <logger>logger</logger>
                    <thread>thread</thread>
                    <mdc>mdc</mdc>
                    <message>message</message>
                    <stackTrace>stackTrace</stackTrace>
                </fieldNames>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>

        <logger name="com.photoizer.crm" level="INFO"/>
        <logger name="com.photoizer.crm.shared.logging" level="WARN"/>
    </springProfile>

    <!-- Perfil de Produção: JSON console + JSON file com AsyncAppender, INFO -->
    <springProfile name="prod">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdc>true</includeMdc>
                <fieldNames>
                    <timestamp>@timestamp</timestamp>
                    <version>[ignore]</version>
                    <levelValue>[ignore]</levelValue>
                    <logger>logger</logger>
                    <thread>thread</thread>
                    <mdc>mdc</mdc>
                    <message>message</message>
                    <stackTrace>stackTrace</stackTrace>
                </fieldNames>
            </encoder>
        </appender>

        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH:-logs}/${applicationName}.json</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH:-logs}/${applicationName}-%d{yyyy-MM-dd}.%i.json</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>30</maxHistory>
                <totalSizeCap>3GB</totalSizeCap>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdc>true</includeMdc>
                <fieldNames>
                    <timestamp>@timestamp</timestamp>
                    <version>[ignore]</version>
                    <levelValue>[ignore]</levelValue>
                    <logger>logger</logger>
                    <thread>thread</thread>
                    <mdc>mdc</mdc>
                    <message>message</message>
                    <stackTrace>stackTrace</stackTrace>
                </fieldNames>
            </encoder>
        </appender>

        <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>1024</queueSize>
            <neverBlock>true</neverBlock>
            <discardingThreshold>0</discardingThreshold>
            <appender-ref ref="FILE"/>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
            <appender-ref ref="ASYNC_FILE"/>
        </root>

        <logger name="com.photoizer.crm" level="INFO"/>
        <logger name="com.photoizer.crm.shared.logging" level="WARN"/>
    </springProfile>
</configuration>
